{
  "name": "tessel",
  "version": "0.1.0",
  "private": true,
  "author": "Tessel contributors",
  "description": "A focused PDF reader with persistent AI conversations and reading progress.",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "dist:win": "pnpm build && electron-builder --win --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "pnpm test:e2e",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:run": "playwright test",
    "ci": "pnpm build && pnpm test:e2e:run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@react-pdf-viewer/bookmark": "^3.12.0",
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/default-layout": "^3.12.0",
    "@react-pdf-viewer/highlight": "^3.12.0",
    "@react-pdf-viewer/page-navigation": "^3.12.0",
    "@react-pdf-viewer/scroll-mode": "^3.12.0",
    "@react-pdf-viewer/search": "^3.12.0",
    "@react-pdf-viewer/selection-mode": "^3.12.0",
    "@react-pdf-viewer/zoom": "^3.12.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron-vite": "^4.0.0",
    "electron-updater": "^6.8.9",
    "katex": "^0.16.22",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "electron": "^38.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "app.sidelight.reader",
    "productName": "Tessel",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "src/assets/icons/icon_256x256.png",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "fogsong233",
        "repo": "notetaker"
      }
    ],
    "mac": {
      "icon": "src/assets/icons/Tessel.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "src/assets/icons/Tessel.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
